---
import { t, resolveLocale, type DictKey } from "../i18n";

const locale = resolveLocale(Astro.currentLocale);

type Project = {
  titleKey: DictKey;
  taglineKey: DictKey;
  descKey: DictKey;
  tags: string[];
  link?: { url: string; labelKey: DictKey };
};

const projects: Project[] = [
  {
    titleKey: "proj1_title",
    taglineKey: "proj1_tagline",
    descKey: "proj1_desc",
    tags: ["Terraform", "Azure", "AVM", "IaC", "GitHub Actions"],
    link: {
      url: "https://github.com/John6810/terraform-azurerm-modules",
      labelKey: "proj1_link",
    },
  },
  {
    titleKey: "proj2_title",
    taglineKey: "proj2_tagline",
    descKey: "proj2_desc",
    tags: ["Python", "FastAPI", "Kubernetes", "ArgoCD", "Docker", "pytest"],
  },
  {
    titleKey: "proj3_title",
    taglineKey: "proj3_tagline",
    descKey: "proj3_desc",
    tags: ["Kubernetes", "ArgoCD", "Traefik", "Prometheus", "MetalLB", "Sealed Secrets"],
  },
];
---

<section id="projects" class="card p-8">
  <h2 class="h-section">{t("section_projects", locale)}</h2>

  <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      projects.map((p) => (
        <article class="card-soft flex flex-col gap-3 p-5 transition duration-300 hover:translate-y-[-2px]">
          <header class="flex flex-col gap-1">
            <h3 class="text-ink text-base leading-snug font-extrabold">{t(p.titleKey, locale)}</h3>
            <p class="text-accent font-mono text-[11px] tracking-[0.06em] uppercase">
              {t(p.taglineKey, locale)}
            </p>
          </header>
          <p class="text-muted text-sm leading-relaxed">{t(p.descKey, locale)}</p>
          <div class="mt-auto flex flex-wrap gap-1.5 pt-2">
            {p.tags.map((tg) => (
              <span class="tag">{tg}</span>
            ))}
          </div>
          {p.link && (
            <a
              href={p.link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent mt-1 inline-flex items-baseline gap-1 self-start text-[13px] font-medium decoration-2 underline-offset-4 transition-colors hover:underline"
            >
              {t(p.link.labelKey, locale)}
            </a>
          )}
        </article>
      ))
    }
  </div>
</section>
