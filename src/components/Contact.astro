---
import { t, resolveLocale } from "../i18n";

const locale = resolveLocale(Astro.currentLocale);
---

<section id="contact" class="card p-8">
  <h2 class="h-section">{t("section_contact", locale)}</h2>

  <p class="text-muted mt-4 max-w-2xl text-sm leading-relaxed sm:text-base sm:leading-relaxed">
    {t("contact_desc", locale)}
  </p>

  <div class="mt-8 flex flex-wrap gap-3">
    <a
      data-email-link
      href="#"
      class="bg-ink text-paper hover:bg-ink-soft inline-flex h-10 items-center gap-2 rounded-md px-4 text-sm font-medium shadow-sm transition select-none active:translate-y-px"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg
      >
      <span data-email-text>hi&#64;jonathan-aerts.dev</span>
    </a>
    <a
      href="https://www.linkedin.com/in/jaerts085/"
      target="_blank"
      rel="noopener noreferrer"
      class="border-line bg-paper text-ink-soft hover:bg-bg-soft hover:text-accent inline-flex h-10 items-center gap-2 rounded-md border px-4 text-sm font-medium transition select-none active:translate-y-px"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
        ><path
          d="M4.98 3.5a2.5 2.5 0 1 1 .02 5 2.5 2.5 0 0 1-.02-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.06c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.07 1.4-2.07 2.86V21h-4V9z"
        ></path></svg
      >
      LinkedIn
    </a>
    <span
      class="border-line bg-bg-soft text-ink-soft inline-flex h-10 items-center gap-2 rounded-md border px-4 text-sm"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z"></path><circle
          cx="12"
          cy="9"
          r="2.5"></circle></svg
      >
      <span>{t("contact_loc", locale)}</span>
    </span>
  </div>
</section>
