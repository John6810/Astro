---
import { withBase } from "../lib/url";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  themeColor?: string;
  noindex?: boolean;
}
const {
  title,
  description = "Senior Cloud Platform Architect with 15+ years IT experience. Specialized in Azure Landing Zones, Terraform/GitOps, multi-region governance, and enterprise-scale cloud platforms.",
  ogImage = "/images/og-preview.png",
  canonicalURL,
  themeColor = "#f5f1ea",
  noindex = false,
} = Astro.props;

// Build canonical from Astro.site + current pathname when not explicitly provided.
const computedCanonical =
  canonicalURL ??
  (Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname);

const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/+$/, "") : "";
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteOrigin}${withBase(ogImage)}`;

// Inline @font-face needs the resolved URL at build time
const interFontUrl = withBase("/fonts/Inter-roman.var.woff2");

// Person JSON-LD — site-level identity, points at canonical site root
const personUrl = siteOrigin
  ? `${siteOrigin}${import.meta.env.BASE_URL.replace(/\/+$/, "")}/`
  : "/";
const personImage = `${siteOrigin}${withBase("/images/avatar.jpg")}`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content={themeColor} />

<link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32x32.png")} />
<link rel="icon" type="image/png" sizes="16x16" href={withBase("/favicon-16x16.png")} />
<link rel="apple-touch-icon" sizes="180x180" href={withBase("/apple-touch-icon.png")} />
<link rel="manifest" href={withBase("/site.webmanifest")} />
<link
  rel="alternate"
  type="application/rss+xml"
  title="Jonathan Aerts — Blog"
  href={withBase("/rss.xml")}
/>

<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
<link rel="canonical" href={computedCanonical} />
<meta name="author" content="Jonathan Aerts" />

<meta property="og:type" content="profile" />
<meta property="og:url" content={computedCanonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:locale" content="fr_BE" />
<meta property="og:locale:alternate" content="en_US" />
<meta property="og:locale:alternate" content="ja_JP" />
<meta property="og:site_name" content="Jonathan Aerts — Cloud Architect Portfolio" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Jonathan Aerts",
    jobTitle: "Senior Cloud Platform Architect",
    url: personUrl,
    email: "hi@jonathan-aerts.dev",
    image: personImage,
    sameAs: ["https://linkedin.com/in/jaerts085/"],
    knowsAbout: [
      "Azure Landing Zone",
      "Terraform",
      "Terragrunt",
      "Azure CAF",
      "Virtual WAN",
      "Defender for Cloud",
      "Sentinel",
      "Kubernetes",
      "AWS",
      "HashiCorp",
    ],
    knowsLanguage: ["fr", "en", "ja"],
    worksFor: { "@type": "Organization", name: "POST Luxembourg" },
    alumniOf: { "@type": "EducationalOrganization", name: "Haute École de la Province de Liège" },
    address: { "@type": "PostalAddress", addressCountry: "BE" },
  })}
/>

<title>{title}</title>

<!-- Inter v3 self-hosted: define @font-face here so the URL respects `base` -->
<style is:global define:vars={{ interFontUrl: `url("${interFontUrl}")` }}>
  @font-face {
    font-family: "Inter var";
    font-style: normal;
    font-weight: 100 900;
    font-display: swap;
    src: var(--interFontUrl) format("woff2");
  }
</style>
