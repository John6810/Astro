---
import { withBase } from "../lib/url";
import { HTML_LANG, OG_LOCALE, t, type Locale, LOCALES, DEFAULT_LOCALE } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  themeColor?: string;
  noindex?: boolean;
  /**
   * When set, emit hreflang alternates for all locales pointing at the
   * locale-prefixed variants of the current path. Use this for pages that
   * exist in every locale (i.e. the i18n-routed root). Omit it for pages
   * that are only published in one language (e.g. blog post pages).
   */
  locale?: Locale;
}

const {
  title,
  description,
  ogImage = "/images/og-preview.png",
  canonicalURL,
  themeColor = "#f5f1ea",
  noindex = false,
  locale,
} = Astro.props;

const resolvedLocale: Locale = locale ?? DEFAULT_LOCALE;
const resolvedTitle = title ?? t("meta_title", resolvedLocale);
const resolvedDescription = description ?? t("meta_description", resolvedLocale);

// ── Canonical + hreflang alternates ──────────────────────────────────────
// Strip a leading /fr or /ja segment from the current pathname to get the
// "canonical path" shared across all locales.
const canonicalPath = Astro.url.pathname.replace(/^\/(fr|ja)(\/|$)/, "/");

const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/+$/, "") : "";

function localeHref(loc: Locale): string {
  if (loc === DEFAULT_LOCALE) return `${siteOrigin}${canonicalPath}`;
  // Insert the locale prefix while preserving the rest of the path.
  const path = canonicalPath === "/" ? `/${loc}/` : `/${loc}${canonicalPath}`;
  return `${siteOrigin}${path}`;
}

const computedCanonical = canonicalURL ?? localeHref(resolvedLocale);

const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteOrigin}${withBase(ogImage)}`;

// Inline @font-face needs the resolved URL at build time
const interFontUrl = withBase("/fonts/Inter-roman.var.woff2");

// Person JSON-LD — site-level identity, points at canonical site root.
// Same content on every locale (the description field is identity-level prose,
// not page-level meta — kept English/neutral by design).
const personUrl = siteOrigin
  ? `${siteOrigin}${import.meta.env.BASE_URL.replace(/\/+$/, "")}/`
  : "/";
const personImage = `${siteOrigin}${withBase("/images/avatar.jpg")}`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content={themeColor} />

<link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32x32.png")} />
<link rel="icon" type="image/png" sizes="16x16" href={withBase("/favicon-16x16.png")} />
<link rel="apple-touch-icon" sizes="180x180" href={withBase("/apple-touch-icon.png")} />
<link rel="manifest" href={withBase("/site.webmanifest")} />
<link
  rel="alternate"
  type="application/rss+xml"
  title="Jonathan Aerts — Blog"
  href={withBase("/rss.xml")}
/>

<meta name="description" content={resolvedDescription} />
<meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
<link rel="canonical" href={computedCanonical} />
<meta name="author" content="Jonathan Aerts" />

{
  /* Emit hreflang alternates only for pages that exist in every locale.
   * For single-language pages (blog posts, etc.) we omit them so search
   * engines don't think a non-existent localized variant is missing. */
  locale && (
    <>
      {LOCALES.map((loc) => (
        <link rel="alternate" hreflang={HTML_LANG[loc]} href={localeHref(loc)} />
      ))}
      <link rel="alternate" hreflang="x-default" href={localeHref(DEFAULT_LOCALE)} />
    </>
  )
}

<meta property="og:type" content="profile" />
<meta property="og:url" content={computedCanonical} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={resolvedDescription} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:locale" content={OG_LOCALE[resolvedLocale]} />
{
  LOCALES.filter((l) => l !== resolvedLocale).map((l) => (
    <meta property="og:locale:alternate" content={OG_LOCALE[l]} />
  ))
}
<meta property="og:site_name" content="Jonathan Aerts — Cloud Architect Portfolio" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={resolvedTitle} />
<meta name="twitter:description" content={resolvedDescription} />
<meta name="twitter:image" content={fullOgImage} />

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Jonathan Aerts",
    givenName: "Jonathan",
    familyName: "Aerts",
    jobTitle: "Senior Cloud Platform Architect",
    description:
      "Senior Cloud Platform Architect, 15+ years of IT experience. Specialized in Azure Landing Zones from scratch, Terraform/Terragrunt, enterprise governance, regulated environments (CSSF, DORA, NIS2, ISO 27001).",
    url: personUrl,
    email: "hi@jonathan-aerts.dev",
    image: personImage,
    address: {
      "@type": "PostalAddress",
      addressCountry: "BE",
      addressRegion: "Wallonie",
    },
    workLocation: [
      {
        "@type": "Place",
        name: "Luxembourg",
        address: {
          "@type": "PostalAddress",
          addressCountry: "LU",
        },
      },
      {
        "@type": "Place",
        name: "EU Remote",
      },
    ],
    worksFor: {
      "@type": "Organization",
      name: "POST Luxembourg",
      url: "https://www.post.lu/",
    },
    alumniOf: {
      "@type": "EducationalOrganization",
      name: "Haute École de la Province de Liège",
      url: "https://www.hepl.be/",
    },
    knowsAbout: [
      "Azure Landing Zone",
      "Microsoft Cloud Adoption Framework",
      "Azure Verified Modules",
      "Terraform",
      "Terragrunt",
      "Infrastructure as Code",
      "GitOps",
      "Argo CD",
      "Azure Kubernetes Service",
      "Kubernetes",
      "Hub-Spoke Networking",
      "Azure Virtual WAN",
      "ExpressRoute",
      "Palo Alto VM-Series",
      "Microsoft Defender for Cloud",
      "Microsoft Sentinel",
      "Microsoft Entra ID",
      "Conditional Access",
      "Privileged Identity Management",
      "Azure Policy",
      "RBAC",
      "Azure Key Vault",
      "Workload Identity",
      "Azure Monitor",
      "Managed Prometheus",
      "Grafana",
      "Microsoft 365",
      "Intune",
      "VMware vSphere",
      "Cisco Meraki SD-WAN",
      "CSSF Circular 22/806",
      "DORA",
      "NIS2",
      "ISO 27001",
      "CIS Benchmarks",
      "Cloud Outsourcing",
      "Platform Engineering",
      "Amazon Web Services",
      "AWS Control Tower",
      "AWS Organizations",
      "Service Control Policies",
    ],
    hasCredential: [
      {
        "@type": "EducationalOccupationalCredential",
        name: "Microsoft Certified: Azure Administrator Associate (AZ-104)",
        credentialCategory: "certification",
      },
      {
        "@type": "EducationalOccupationalCredential",
        name: "Microsoft Certified: Azure Security Engineer Associate (AZ-500)",
        credentialCategory: "certification",
      },
      {
        "@type": "EducationalOccupationalCredential",
        name: "Microsoft Certified: Azure Network Engineer Associate (AZ-700)",
        credentialCategory: "certification",
      },
      {
        "@type": "EducationalOccupationalCredential",
        name: "HashiCorp Certified: Terraform Associate",
        credentialCategory: "certification",
      },
    ],
    knowsLanguage: [
      { "@type": "Language", name: "French", alternateName: "fr" },
      { "@type": "Language", name: "English", alternateName: "en" },
      { "@type": "Language", name: "Japanese", alternateName: "ja" },
    ],
    sameAs: ["https://linkedin.com/in/jaerts085", "https://github.com/john6810"],
  })}
/>

<title>{resolvedTitle}</title>

<!-- Inter v3 self-hosted: define @font-face here so the URL respects `base` -->
<style is:global define:vars={{ interFontUrl: `url("${interFontUrl}")` }}>
  @font-face {
    font-family: "Inter var";
    font-style: normal;
    font-weight: 100 900;
    font-display: swap;
    src: var(--interFontUrl) format("woff2");
  }
</style>
