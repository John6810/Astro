---
import { withBase } from "../lib/url";
import { t, resolveLocale } from "../i18n";

const locale = resolveLocale(Astro.currentLocale);

// Certifications and degree are technical labels — same across locales.
const certsDone = [
  "AZ-104 — Azure Administrator",
  "AZ-500 — Azure Security Engineer",
  "AZ-700 — Azure Network Engineer",
  "HashiCorp Terraform Associate",
];
const certsWip = ["AZ-305 — Azure Solutions Architect Expert", "AWS Solutions Architect Associate"];
---

<section id="education" class="card p-8">
  <h2 class="h-section">{t("section_education", locale)}</h2>

  <div class="mt-8 grid gap-10 sm:grid-cols-2">
    <!-- Degree -->
    <div class="edu-item flex flex-col gap-2">
      <span class="eyebrow">{t("edu_eb_diplome", locale)}</span>
      <h3 class="text-ink text-base leading-snug font-extrabold">
        {t("edu_degree_title", locale)}
      </h3>
      <p class="text-muted text-sm">{t("edu_degree_school", locale)}</p>
    </div>

    <!-- Languages -->
    <div class="edu-item flex flex-col gap-2">
      <span class="eyebrow">{t("edu_eb_langs", locale)}</span>
      <h3 class="sr-only">{t("edu_langs_title", locale)}</h3>
      <ul class="text-ink-soft mt-1 flex flex-col gap-2 text-sm">
        <li class="flex items-center gap-3">
          <img
            src={withBase("/icons/flag-fr.svg")}
            alt=""
            width="16"
            height="12"
            class="inline-block h-3 w-4 flex-none rounded-[2px] object-cover"
            loading="lazy"
          />
          <span>{t("lang_fr", locale)}</span>
        </li>
        <li class="flex items-center gap-3">
          <img
            src={withBase("/icons/flag-gb.svg")}
            alt=""
            width="16"
            height="12"
            class="inline-block h-3 w-4 flex-none rounded-[2px] object-cover"
            loading="lazy"
          />
          <span>{t("lang_en", locale)}</span>
        </li>
        <li class="flex items-center gap-3">
          <img
            src={withBase("/icons/flag-jp.svg")}
            alt=""
            width="16"
            height="12"
            class="inline-block h-3 w-4 flex-none rounded-[2px] object-cover"
            loading="lazy"
          />
          <span>{t("lang_jp", locale)}</span>
        </li>
      </ul>
    </div>

    <!-- Certs obtained -->
    <div class="edu-item flex flex-col gap-2">
      <span class="eyebrow">{t("edu_eb_certs_done", locale)}</span>
      <h3 class="sr-only">{t("edu_certs_done_title", locale)}</h3>
      <ul class="mt-1 flex flex-col gap-2">
        {
          certsDone.map((c) => (
            <li class="text-ink-soft flex items-center gap-2 text-sm">
              <span
                class="grid h-4 w-4 flex-none place-items-center rounded-md bg-[color:color-mix(in_oklab,#22c55e_22%,transparent)] text-[#16a34a]"
                aria-hidden="true"
              >
                <svg
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              <span>{c}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Certs WIP -->
    <div class="edu-item flex flex-col gap-2">
      <span class="eyebrow">{t("edu_eb_certs_wip", locale)}</span>
      <h3 class="sr-only">{t("edu_certs_wip_title", locale)}</h3>
      <ul class="mt-1 flex flex-col gap-2">
        {
          certsWip.map((c) => (
            <li class="text-ink-soft flex items-center gap-2 text-sm">
              <span
                class="text-accent grid h-4 w-4 flex-none place-items-center rounded-md bg-[color:color-mix(in_oklab,var(--accent)_22%,transparent)]"
                aria-hidden="true"
              >
                <svg
                  width="9"
                  height="9"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                >
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </span>
              <span>{c}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
