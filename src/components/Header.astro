---
// Devscard-style header. Strings resolved server-side via t() — no client-side
// data-i18n swap anymore. The language switcher (the FR/EN/JP pills here in
// the legacy version) is replaced by a real-navigation switcher in commit 6.
import { withBase } from "../lib/url";
import { t, resolveLocale } from "../i18n";

const locale = resolveLocale(Astro.currentLocale);
---

<section id="about" class="card p-8">
  <div class="flex flex-col items-start gap-6 sm:flex-row sm:gap-12">
    <!-- Left: photo + Download CV button -->
    <div class="flex flex-none flex-col items-center gap-4">
      <img
        src={withBase("/images/avatar.jpg")}
        alt="Photo de profil de Jonathan Aerts, Senior Cloud Platform Architect"
        width="208"
        height="208"
        loading="eager"
        fetchpriority="high"
        class="h-24 w-24 max-w-none rounded-lg object-cover sm:h-36 sm:w-36 md:h-52 md:w-52"
      />
      <a
        href={withBase("/cv.pdf")}
        download
        class="no-print bg-ink text-paper hover:bg-ink-soft inline-flex h-10 w-full items-center justify-center rounded-md px-4 text-base font-medium shadow-sm transition select-none active:translate-y-px"
      >
        {t("hero_cta_cv", locale)}
      </a>
    </div>

    <!-- Right: identity + socials + lang switcher + info grid + description + tags -->
    <div class="flex w-full flex-col gap-4">
      <!-- Name + social row -->
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h1
            id="top"
            class="text-ink text-3xl leading-tight font-extrabold tracking-tight sm:text-4xl"
          >
            Jonathan Aerts
          </h1>
          <p class="text-ink-soft mt-1.5 text-[15px] font-normal">{t("hero_role", locale)}</p>
        </div>

        <div class="flex flex-col items-start gap-2 sm:items-end">
          <!-- Language switcher placeholder — actual interactive switcher arrives in commit 6.
               These buttons currently no-op (the legacy data-i18n swap was removed). -->
          <div
            class="border-line bg-paper flex items-center gap-0.5 rounded-md border p-0.5"
            role="group"
            aria-label="Change language"
          >
            <button
              type="button"
              data-lang="fr"
              aria-pressed={locale === "fr"}
              class:list={["lang-btn", locale === "fr" && "is-active"]}>FR</button
            >
            <button
              type="button"
              data-lang="en"
              aria-pressed={locale === "en"}
              class:list={["lang-btn", locale === "en" && "is-active"]}>EN</button
            >
            <button
              type="button"
              data-lang="jp"
              aria-pressed={locale === "ja"}
              class:list={["lang-btn", locale === "ja" && "is-active"]}>JP</button
            >
          </div>

          <!-- Social icons -->
          <div class="flex gap-1.5">
            <a
              href="https://github.com/john6810"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
              class="text-muted hover:text-accent grid h-8 w-8 flex-none place-items-center rounded bg-[color:var(--bg-soft)] transition hover:bg-[color:var(--line)]"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
                ><path
                  d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.77 1.06.77 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
                ></path></svg
              >
            </a>
            <a
              href="https://linkedin.com/in/jaerts085/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="text-muted hover:text-accent grid h-8 w-8 flex-none place-items-center rounded bg-[color:var(--bg-soft)] transition hover:bg-[color:var(--line)]"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
                ><path
                  d="M4.98 3.5a2.5 2.5 0 1 1 .02 5 2.5 2.5 0 0 1-.02-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.06c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.07 1.4-2.07 2.86V21h-4V9z"
                ></path></svg
              >
            </a>
            <a
              data-email-link
              href="#"
              aria-label="Email"
              class="text-muted hover:text-accent grid h-8 w-8 flex-none place-items-center rounded bg-[color:var(--bg-soft)] transition hover:bg-[color:var(--line)]"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"
                ></path></svg
              >
            </a>
          </div>
        </div>
      </div>

      <!-- Info grid -->
      <div class="flex flex-col gap-1">
        <div class="grid gap-x-6 gap-y-1 sm:grid-cols-2">
          <div>
            <span class="text-ink-soft text-base font-medium">{t("hero_label_email", locale)}</span>
            <span> </span>
            <a
              data-email-link
              href="#"
              class="text-ink-soft hover:text-accent text-base leading-relaxed font-normal decoration-from-font underline-offset-2 transition-colors hover:underline"
            >
              <span data-email-text>hi&#64;jonathan-aerts.dev</span>
            </a>
          </div>
          <div>
            <span class="text-ink-soft text-base font-medium">{t("hero_label_from", locale)}</span>
            <span> </span>
            <span class="text-ink-soft text-base font-normal">{t("hero_value_from", locale)}</span>
          </div>
          <div class="inline-flex items-baseline gap-1.5">
            <span class="text-ink-soft text-base font-medium"
              >{t("hero_label_currently", locale)}</span
            >
            <img
              src={withBase("/images/companies/post-logo.webp")}
              alt="POST Luxembourg"
              width="32"
              height="24"
              class="inline-block h-[1.2em] w-auto flex-none self-center"
              loading="lazy"
            />
            <span class="text-ink-soft text-base font-normal"
              >{t("hero_value_currently", locale)}</span
            >
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-x-1.5 gap-y-1">
          <span class="text-ink-soft text-base font-medium"
            >{t("hero_label_languages", locale)}</span
          >
          <span class="text-ink-soft inline-flex items-center gap-1.5 text-base font-normal">
            <img
              src={withBase("/icons/flag-fr.svg")}
              alt=""
              width="16"
              height="12"
              class="inline-block h-3 w-4 flex-none rounded-[2px] object-cover"
              loading="lazy"
            />
            FR
          </span>
          <span aria-hidden="true" class="text-muted">·</span>
          <span class="text-ink-soft inline-flex items-center gap-1.5 text-base font-normal">
            <img
              src={withBase("/icons/flag-gb.svg")}
              alt=""
              width="16"
              height="12"
              class="inline-block h-3 w-4 flex-none rounded-[2px] object-cover"
              loading="lazy"
            />
            EN
          </span>
          <span aria-hidden="true" class="text-muted">·</span>
          <span class="text-ink-soft inline-flex items-center gap-1.5 text-base font-normal">
            <img
              src={withBase("/icons/flag-jp.svg")}
              alt=""
              width="16"
              height="12"
              class="inline-block h-3 w-4 flex-none rounded-[2px] object-cover"
              loading="lazy"
            />
            JP
          </span>
        </div>
      </div>

      <!-- Description — contains inline HTML, so set:html. -->
      <p
        class="text-muted text-sm leading-relaxed font-normal sm:text-base sm:leading-relaxed"
        set:html={t("hero_desc", locale)}
      />

      <!-- Status tag pills -->
      <div class="flex flex-wrap gap-2">
        <span class="tag">Azure Landing Zone</span>
        <span class="tag">Terraform · Terragrunt</span>
        <span class="tag">GitOps · Platform Engineering</span>
      </div>
    </div>
  </div>
</section>

<style>
  .lang-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 4px 8px;
    border-radius: 4px;
    color: var(--muted);
    background: transparent;
    border: none;
    cursor: pointer;
    transition:
      color 0.15s,
      background 0.15s;
  }
  .lang-btn:hover {
    color: var(--ink);
    background: var(--bg-soft);
  }
  .lang-btn.is-active {
    background: var(--accent);
    color: var(--accent-on);
  }
</style>
