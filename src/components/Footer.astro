---
const year = new Date().getFullYear();
// __BUILD_DATE__ is replaced at build time by vite.define (astro.config.mjs).
// Format: "November 16, 2025".
const buildDate = __BUILD_DATE__;
---

<footer
  class="no-print text-muted mt-4 flex flex-col items-center justify-between gap-2 pt-2 text-center text-xs sm:flex-row sm:text-left"
>
  <div class="flex flex-col items-center gap-0.5 sm:items-start">
    <span>© {year} Jonathan Aerts</span>
    <span class="text-[11px] opacity-70">Last updated: {buildDate}</span>
  </div>
  <span class="font-mono tracking-[0.04em]" data-i18n="footer_built"
    >Built with Astro · Tailwind v4 · Inter</span
  >
</footer>
