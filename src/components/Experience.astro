    references: [
      {
        url: "https://www.microsoft.com/en/customers/story/24351-post-luxembourg-azure",
        labelKey: "job1_link_ms",
      },
      {
        url: "https://github.com/John6810/terraform-azurerm-modules",
        labelKey: "job1_link_github",
      },
    ],
  },
  {
    titleKey: "job2_title",
    companyKey: "job2_company",
    metaKey: "job2_meta",
    dateKey: "job2_date",
    contextKey: "job2_context",
    logo: "/images/companies/alten-logo.webp",
    bulletsKeys: ["job2_b1", "job2_b2", "job2_b3", "job2_b4", "job2_b5"],
    tags: [
      "Azure",
      "Terraform",
      "Microsoft 365",
      "Exchange Online",
      "Entra ID",
      "Conditional Access",
      "MFA",
      "Microsoft Compliance Center",
      "CIS Baselines",
      "Microsoft CAF",
    ],
  },
  {
    titleKey: "job3_title",
    companyKey: "job3_company",
    metaKey: "job3_meta",
    dateKey: "job3_date",
