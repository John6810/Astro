---

<section id="experience" class="card p-8">
  <h2 class="h-section" data-i18n="section_experience">Expérience professionnelle</h2>

  <div class="mt-8 flex flex-col gap-10">
    {
      jobs.map((job) => (
        <article class="job border-line flex flex-col gap-3 border-b pb-10 last:border-b-0 last:pb-0">
          <header class="flex items-start gap-4 sm:gap-5">
            {job.logo && (
              <img
                src={job.logo}
                alt={job.company}
                width="48"
                height="48"
                loading="lazy"
                class="mt-0.5 h-10 w-auto flex-none rounded sm:h-12"
              />
            )}
            <div class="flex min-w-0 flex-1 flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
              <div class="min-w-0">
                <h3 class="text-ink text-lg leading-snug font-extrabold" data-i18n={job.titleKey}>
                  {job.title}
                </h3>
                <p class="text-muted mt-0.5 text-sm">
                  <span class="text-accent font-medium" data-i18n={job.companyKey}>
                    {job.company}
                  </span>
                  {job.meta && (
                    <>
                      {" "}
                      · <span data-i18n={job.metaKey}>{job.meta}</span>
                    </>
                  )}
                </p>
              </div>
              <span
                class="text-muted font-mono text-xs tracking-[0.06em] whitespace-nowrap uppercase"
                data-i18n={job.dateKey}
              >
                {job.date}
              </span>
            </div>
          </header>

          <p
            class="text-muted text-sm leading-relaxed italic"
            data-i18n={job.contextKey}
            set:html={job.context}
          />

          <ul class="flex flex-col gap-2">
            {job.bullets.map((b, i) => (
              <li class="text-ink-soft grid grid-cols-[12px_1fr] gap-3 text-sm leading-relaxed sm:text-[15px]">
                <span class="bg-accent mt-2 inline-block h-1 w-1 rounded-full" aria-hidden="true" />
                <span data-i18n={job.bulletsKeys[i]} set:html={b} />
              </li>
            ))}
          </ul>

          <div class="mt-2 flex flex-wrap gap-1.5">
            {job.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>

          {job.refs && job.refs.length > 0 && (
            <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1.5">
              <span
                class="text-muted font-mono text-[10px] tracking-[0.12em] uppercase"
                data-i18n="exp_refs_eyebrow"
              >
                Référentiels
              </span>
              <div class="flex flex-wrap gap-1.5">
                {job.refs.map((r) => (
                  <span class="tag-ref">{r}</span>
                ))}
              </div>
            </div>
          )}

          {job.references && job.references.length > 0 && (
            <div class="border-line mt-2 flex flex-col gap-2 border-l-2 pl-4">
              <span
                class="text-muted font-mono text-[10px] tracking-[0.12em] uppercase"
                data-i18n="exp_sources_eyebrow"
              >
                Sources & références
              </span>
              {job.references.map((r) => (
                <a
                  href={r.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent inline-flex items-baseline gap-1 self-start text-sm font-medium decoration-2 underline-offset-4 transition-colors hover:underline"
                  data-i18n={r.labelKey}
                >
                  {r.label}
                </a>
              ))}
            </div>
          )}
        </article>
      ))
    }

    {
      earlier.length > 0 && (
        <details class="group">
          <summary class="bg-bg-soft hover:bg-line flex cursor-pointer list-none items-center justify-between gap-4 rounded-lg px-5 py-3 transition">
            <span class="text-ink-soft text-sm font-medium" data-i18n="earlier_title">
              Expériences précédentes
            </span>
            <span
              class="text-muted font-mono text-xs transition group-open:rotate-180"
              aria-hidden="true"
            >
              ▾
            </span>
          </summary>
          <div class="mt-4 flex flex-col">
            {earlier.map((e) => (
              <div class="border-line grid gap-1 border-t py-3 first:border-t-0 sm:grid-cols-[1fr_auto] sm:items-baseline sm:gap-6">
                <div>
                  <span class="text-ink text-sm" data-i18n={e.titleKey}>
                    {e.title}
                  </span>
                  <span class="text-muted ml-2 text-[13px]" data-i18n={e.companyKey}>
                    {e.company}
                  </span>
                </div>
                <span
                  class="text-muted font-mono text-xs tracking-[0.05em] uppercase"
                  data-i18n={e.dateKey}
                >
                  {e.date}
                </span>
              </div>
            ))}
          </div>
        </details>
      )
    }
  </div>
</section>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary::marker {
    content: "";
  }
</style>
