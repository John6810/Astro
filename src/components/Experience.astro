    dateKey: "job1_date",
    contextKey: "job1_context",
    logo: "/images/companies/post-logo.webp",
    bulletsKeys: ["job1_b1", "job1_b2", "job1_b3", "job1_b4", "job1_b5", "job1_b6", "job1_b7"],
    tags: [
      "Azure",
