      "Microsoft 365",
    ],
    refs: ["CSSF AIFMD", "ISO 27001", "CIS Benchmarks", "RGPD", "Microsoft CAF"],
  },
  {
    titleKey: "job4_title",
    companyKey: "job4_company",
    metaKey: "job4_meta",
