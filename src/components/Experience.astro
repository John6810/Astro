---

<section id="experience" class="card p-8">
  <h2 class="h-section">{t("section_experience", locale)}</h2>

  <div class="mt-8 flex flex-col gap-10">
    {
      jobs.map((job) => (
        <article class="job border-line flex flex-col gap-3 border-b pb-10 last:border-b-0 last:pb-0">
          <header class="flex items-start gap-4 sm:gap-5">
            {job.logo && (
              <img
                src={withBase(job.logo)}
                alt={t(job.companyKey, locale)}
                width="48"
                height="48"
                loading="lazy"
                class="mt-0.5 h-10 w-auto flex-none rounded sm:h-12"
              />
            )}
            <div class="flex min-w-0 flex-1 flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
              <div class="min-w-0">
                <h3 class="text-ink text-lg leading-snug font-extrabold">
                  {t(job.titleKey, locale)}
                </h3>
                <p class="text-muted mt-0.5 text-sm">
                  <span class="text-accent font-medium">{t(job.companyKey, locale)}</span>
                  {job.metaKey && (
                    <>
                      {" "}
                      · <span>{t(job.metaKey, locale)}</span>
                    </>
                  )}
                </p>
              </div>
              <span class="text-muted font-mono text-xs tracking-[0.06em] whitespace-nowrap uppercase">
                {t(job.dateKey, locale)}
              </span>
            </div>
          </header>

          <p
            class="text-muted text-sm leading-relaxed italic"
            set:html={t(job.contextKey, locale)}
          />

          <ul class="flex flex-col gap-2">
            {job.bulletsKeys.map((bKey) => (
              <li class="text-ink-soft grid grid-cols-[12px_1fr] gap-3 text-sm leading-relaxed sm:text-[15px]">
                <span class="bg-accent mt-2 inline-block h-1 w-1 rounded-full" aria-hidden="true" />
                <span set:html={t(bKey, locale)} />
              </li>
            ))}
          </ul>

          <div class="mt-2 flex flex-wrap gap-1.5">
            {job.tags.map((tg) => (
              <span class="tag">{tg}</span>
            ))}
          </div>

          {job.refs && job.refs.length > 0 && (
            <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1.5">
              <span class="text-muted font-mono text-[10px] tracking-[0.12em] uppercase">
                {t("exp_refs_eyebrow", locale)}
              </span>
              <div class="flex flex-wrap gap-1.5">
                {job.refs.map((r) => (
                  <span class="tag-ref">{r}</span>
                ))}
              </div>
            </div>
          )}

          {job.references && job.references.length > 0 && (
            <div class="border-line mt-2 flex flex-col gap-2 border-l-2 pl-4">
              <span class="text-muted font-mono text-[10px] tracking-[0.12em] uppercase">
                {t("exp_sources_eyebrow", locale)}
              </span>
              {job.references.map((r) => (
                <a
                  href={r.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent inline-flex items-baseline gap-1 self-start text-sm font-medium decoration-2 underline-offset-4 transition-colors hover:underline"
                >
                  {t(r.labelKey, locale)}
                </a>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </div>
</section>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary::marker {
    content: "";
  }
</style>
