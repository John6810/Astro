---

<section id="experience" class="card p-8">
  <h2 class="h-section" data-i18n="section_experience">Expérience professionnelle</h2>

  <div class="mt-8 flex flex-col gap-10">
    {jobs.map((job) => (
      <article class="job flex flex-col gap-3 border-b border-line pb-10 last:border-b-0 last:pb-0">
        <header class="flex items-start gap-4 sm:gap-5">
          {job.logo && (
            <img src={job.logo} alt={job.company} width="48" height="48" loading="lazy"
                 class="mt-0.5 h-10 w-auto flex-none rounded sm:h-12" />
          )}
          <div class="flex min-w-0 flex-1 flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
            <div class="min-w-0">
              <h3 class="text-lg font-extrabold leading-snug text-ink" data-i18n={job.titleKey}>
                {job.title}
              </h3>
              <p class="mt-0.5 text-sm text-muted">
                <span class="font-medium text-accent" data-i18n={job.companyKey}>{job.company}</span>
                {job.meta && <> · <span data-i18n={job.metaKey}>{job.meta}</span></>}
              </p>
            </div>
            <span class="font-mono text-xs uppercase tracking-[0.06em] text-muted whitespace-nowrap" data-i18n={job.dateKey}>
              {job.date}
            </span>
          </div>
        </header>

        <p class="text-sm italic leading-relaxed text-muted" set:html={job.context}></p>

        <ul class="flex flex-col gap-2">
          {job.bullets.map((b) => (
            <li class="grid grid-cols-[12px_1fr] gap-3 text-sm leading-relaxed text-ink-soft sm:text-[15px]">
              <span class="mt-2 inline-block h-1 w-1 rounded-full bg-accent" aria-hidden="true"></span>
              <span set:html={b} />
            </li>
          ))}
        </ul>

        <div class="mt-2 flex flex-wrap gap-1.5">
          {job.tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>

        {job.refs && job.refs.length > 0 && (
          <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1.5">
            <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-muted">Référentiels</span>
            <div class="flex flex-wrap gap-1.5">
              {job.refs.map((r) => (
                <span class="tag-ref">{r}</span>
              ))}
            </div>
          </div>
        )}

        {job.references && job.references.length > 0 && (
          <div class="mt-2 flex flex-col gap-2 border-l-2 border-line pl-4">
            <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-muted">Sources & références</span>
            {job.references.map((r) => (
              <a href={r.url} target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-baseline gap-1 self-start text-sm font-medium text-accent transition-colors decoration-2 underline-offset-4 hover:underline">
                {r.label}
              </a>
            ))}
          </div>
        )}
      </article>
    ))}

    {earlier.length > 0 && (
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-lg bg-bg-soft px-5 py-3 transition hover:bg-line">
          <span class="text-sm font-medium text-ink-soft" data-i18n="earlier_title">Expériences précédentes</span>
          <span class="font-mono text-xs text-muted transition group-open:rotate-180" aria-hidden="true">▾</span>
        </summary>
        <div class="mt-4 flex flex-col">
          {earlier.map((e) => (
            <div class="grid gap-1 border-t border-line py-3 first:border-t-0 sm:grid-cols-[1fr_auto] sm:items-baseline sm:gap-6">
              <div>
                <span class="text-sm text-ink" data-i18n={e.titleKey}>{e.title}</span>
                <span class="ml-2 text-[13px] text-muted" data-i18n={e.companyKey}>{e.company}</span>
              </div>
              <span class="font-mono text-xs uppercase tracking-[0.05em] text-muted" data-i18n={e.dateKey}>
                {e.date}
              </span>
            </div>
          ))}
        </div>
      </details>
    )}
  </div>
</section>

<style>
  details summary::-webkit-details-marker { display: none; }
  details summary::marker { content: ''; }
</style>
