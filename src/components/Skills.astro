---
import { withBase } from "../lib/url";
import { t, resolveLocale, type DictKey } from "../i18n";

const locale = resolveLocale(Astro.currentLocale);

type IconRef = { kind: "img"; src: string } | { kind: "mono"; mono: string; bg: string };

type Level = "EXPERT" | "AVANCÉ";
type Skill = { name: string; icon: IconRef; level: Level };
type Category = { emoji: string; titleKey: DictKey; skills: Skill[] };

const categories: Category[] = [
  {
    emoji: "☁️",
    titleKey: "cat_cloud",
    skills: [
      {
        name: "Azure Landing Zone",
        icon: { kind: "img", src: "/icons/azure-mg.svg" },
        level: "EXPERT",
      },
      {
        name: "Microsoft CAF / Azure Verified Modules",
        icon: { kind: "img", src: "/icons/azure-mg.svg" },
        level: "AVANCÉ",
      },
      {
        name: "AKS / Kubernetes",
        icon: { kind: "img", src: "/icons/kubernetes.svg" },
        level: "AVANCÉ",
      },
    ],
  },
  {
    emoji: "🔧",
    titleKey: "cat_iac",
    skills: [
      { name: "Terraform", icon: { kind: "img", src: "/icons/terraform.svg" }, level: "EXPERT" },
      { name: "Terragrunt", icon: { kind: "img", src: "/icons/terragrunt.webp" }, level: "AVANCÉ" },
      {
        name: "Argo CD / GitOps",
        icon: { kind: "img", src: "/icons/argocd.svg" },
        level: "AVANCÉ",
      },
      {
        name: "Azure DevOps / GitHub Actions",
        icon: { kind: "img", src: "/icons/azuredevops.svg" },
        level: "AVANCÉ",
      },
    ],
  },
  {
    emoji: "🌐",
    titleKey: "cat_network",
    skills: [
      {
        name: "Hub-Spoke / Virtual WAN / ExpressRoute",
        icon: { kind: "img", src: "/icons/vwan.svg" },
        level: "EXPERT",
      },
      {
        name: "Palo Alto VM-Series",
        icon: { kind: "img", src: "/icons/paloalto.svg" },
        level: "AVANCÉ",
      },
      {
        name: "Defender for Cloud / Sentinel",
        icon: { kind: "img", src: "/icons/defender.svg" },
        level: "AVANCÉ",
      },
    ],
  },
  {
    emoji: "🔐",
    titleKey: "cat_identity",
    skills: [
      {
        name: "Entra ID / Conditional Access / PIM",
        icon: { kind: "img", src: "/icons/ca.svg" },
        level: "EXPERT",
      },
      {
        name: "Azure Policy / RBAC",
        icon: { kind: "img", src: "/icons/policy.svg" },
        level: "EXPERT",
      },
      {
        name: "Key Vault / Workload Identity",
        icon: { kind: "img", src: "/icons/keyvault.svg" },
        level: "AVANCÉ",
      },
    ],
  },
  {
    emoji: "📊",
    titleKey: "cat_observ",
    skills: [
      {
        name: "Azure Monitor / Managed Prometheus / Grafana",
        icon: { kind: "img", src: "/icons/monitor.svg" },
        level: "AVANCÉ",
      },
      {
        name: "Microsoft 365 / Exchange Online / Intune",
        icon: { kind: "img", src: "/icons/intune.svg" },
        level: "AVANCÉ",
      },
      {
        name: "VMware vSphere · Cisco / Meraki SD-WAN",
        icon: { kind: "img", src: "/icons/vmware.svg" },
        level: "AVANCÉ",
      },
    ],
  },
];

const levelClass: Record<Level, string> = {
  EXPERT: "text-accent",
  AVANCÉ: "text-ink-soft",
};
const levelKey: Record<Level, DictKey> = {
  EXPERT: "level_expert",
  AVANCÉ: "level_avance",
};

type LearnItem = { name: string; icon: IconRef };
const learning: LearnItem[] = [
  { name: "AWS Landing Zone · Control Tower · SCPs", icon: { kind: "img", src: "/icons/aws.svg" } },
];

const languages: Array<{ src: string; key: DictKey }> = [
  { src: "/icons/flag-fr.svg", key: "lang_fr" },
  { src: "/icons/flag-gb.svg", key: "lang_en" },
  { src: "/icons/flag-jp.svg", key: "lang_jp" },
];
---

<section id="skills" class="card p-8">
  <h2 class="h-section">{t("section_skills", locale)}</h2>

  <div class="mt-8 flex flex-col gap-10">
    <!-- I know -->
    <div>
      <h3 class="text-ink mb-6 text-base font-extrabold">{t("skills_mastering", locale)}</h3>

      <div class="flex flex-col gap-7">
        {
          categories.map((cat) => (
            <div>
              <h4 class="text-ink-soft mb-3 flex items-center gap-2 font-mono text-[11px] tracking-[0.12em] uppercase">
                <span aria-hidden="true">{cat.emoji}</span>
                <span>{t(cat.titleKey, locale)}</span>
              </h4>
              <div class="grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2 lg:grid-cols-3">
                {cat.skills.map((s) => (
                  <div class="flex flex-col gap-1">
                    <div class="flex items-center gap-2">
                      {s.icon.kind === "img" && (
                        <img
                          src={withBase(s.icon.src)}
                          alt=""
                          width="20"
                          height="20"
                          class="h-5 w-5 flex-none object-contain"
                          loading="lazy"
                        />
                      )}
                      {s.icon.kind === "mono" && (
                        <span
                          class="grid h-5 w-5 flex-none place-items-center rounded text-[9px] font-bold text-white"
                          style={`background: ${s.icon.bg}`}
                        >
                          {s.icon.mono}
                        </span>
                      )}
                      <span class="text-ink text-sm leading-tight font-medium">{s.name}</span>
                    </div>
                    <span
                      class={`pl-7 font-mono text-[10px] tracking-[0.1em] uppercase ${levelClass[s.level]}`}
                    >
                      {t(levelKey[s.level], locale)}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Learning -->
    <div>
      <h3 class="text-ink mb-4 text-base font-extrabold">{t("skills_learning", locale)}</h3>
      <div class="flex flex-wrap gap-2">
        {
          learning.map((s) => (
            <span class="border-line bg-paper text-ink inline-flex items-center gap-2 rounded border px-2.5 py-1 text-sm font-medium">
              {s.icon.kind === "img" && (
                <img
                  src={withBase(s.icon.src)}
                  alt=""
                  width="16"
                  height="16"
                  class="h-4 w-4 flex-none object-contain"
                  loading="lazy"
                />
              )}
              {s.icon.kind === "mono" && (
                <span
                  class="grid h-4 w-4 flex-none place-items-center rounded-sm text-[8px] font-bold text-white"
                  style={`background: ${s.icon.bg}`}
                >
                  {s.icon.mono}
                </span>
              )}
              {s.name}
            </span>
          ))
        }
      </div>
    </div>

    <!-- I speak -->
    <div>
      <h3 class="text-ink mb-4 text-base font-extrabold">{t("skills_speak", locale)}</h3>
      <div class="flex flex-wrap gap-2">
        {
          languages.map((l) => (
            <span class="border-line bg-paper text-ink inline-flex items-center gap-2 rounded border px-2.5 py-1 text-sm font-medium">
              <img
                src={withBase(l.src)}
                alt=""
                width="16"
                height="12"
                class="h-3 w-4 flex-none rounded-[2px] object-cover"
                loading="lazy"
              />
              <span>{t(l.key, locale)}</span>
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
