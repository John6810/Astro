---
import TagBadge from "./TagBadge.astro";
import ReadingTime from "./ReadingTime.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  minutes: number;
  tags: string[];
  lang?: "fr" | "en";
  draft?: boolean;
}

const {
  href,
  title,
  description,
  pubDate,
  minutes,
  tags,
  lang = "fr",
  draft = false,
} = Astro.props;

const locale = lang === "en" ? "en-GB" : "fr-FR";
const dateLabel = new Intl.DateTimeFormat(locale, {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(pubDate);

const visibleTags = tags.slice(0, 3);
---

<a
  href={href}
  class="card-soft group flex flex-col gap-3 p-5 transition duration-300 hover:translate-y-[-2px] hover:border-[color:var(--accent-soft)]"
>
  <header class="flex items-baseline justify-between gap-3">
    <span class="text-muted font-mono text-[11px] tracking-[0.08em] uppercase">
      <time datetime={pubDate.toISOString()}>{dateLabel}</time>
    </span>
    {
      draft && (
        <span class="text-accent font-mono text-[10px] tracking-[0.1em] uppercase">draft</span>
      )
    }
  </header>
  <h2 class="text-ink group-hover:text-accent text-lg leading-snug font-extrabold">
    {title}
  </h2>
  <p class="text-muted text-sm leading-relaxed">{description}</p>
  <div class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1.5 pt-2">
    <ReadingTime minutes={minutes} lang={lang} />
    {
      visibleTags.length > 0 && (
        <span aria-hidden="true" class="text-muted">
          ·
        </span>
      )
    }
    <div class="flex flex-wrap gap-1.5">
      {visibleTags.map((t) => <TagBadge tag={t} />)}
    </div>
  </div>
</a>
