---
const stats = [
  { num: '15+',     label: "ans d'IT" },
  { num: '5+',      label: 'ans sur Azure' },
  { num: '60+',     label: 'modules Terraform' },
  { num: '+500K€',  label: 'budget annuel' },
  { num: '35+',     label: 'ingénieurs formés' },
  { num: '4',       label: 'Landing Zones' },
];
---

<section aria-label="Key figures" class="card overflow-hidden">
  <div class="grid grid-cols-2 gap-px bg-line sm:grid-cols-3 lg:grid-cols-6">
    {stats.map((s) => (
      <div class="flex min-h-[110px] flex-col items-center justify-center bg-paper p-5 text-center">
        <div class="whitespace-nowrap text-3xl font-extrabold leading-none tracking-tight text-accent">
          {s.num}
        </div>
        <div class="mt-2 whitespace-nowrap text-[13px] leading-snug text-muted">
          {s.label}
        </div>
      </div>
    ))}
  </div>
</section>
