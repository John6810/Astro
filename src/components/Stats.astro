---
import { t, resolveLocale, type DictKey } from "../i18n";

const locale = resolveLocale(Astro.currentLocale);

// Ordered experience -> scope -> impact, 6 cells matching the lg:grid-cols-6 layout.
const stats: Array<{ num: string; labelKey: DictKey }> = [
  { num: "15+", labelKey: "stat_years_label" },
  { num: "5+", labelKey: "stat_azure_label" },
  { num: "4", labelKey: "stat_alz_label" },
  { num: "26", labelKey: "stat_subscriptions_label" },
  { num: "500K€+", labelKey: "stat_budget_label" },
  { num: "35+", labelKey: "stat_trained_label" },
];
---

<section aria-label="Key figures" class="card overflow-hidden">
  <div class="bg-line grid grid-cols-2 gap-px sm:grid-cols-3 lg:grid-cols-6">
    {
      stats.map((s) => (
        <div class="bg-paper flex min-h-[110px] flex-col items-center justify-center p-5 text-center">
          {/* The number must NEVER wrap (e.g. "500K€+" must stay on one
              line). whitespace-nowrap is correct here. */}
          <div class="text-accent text-3xl leading-none font-extrabold tracking-tight whitespace-nowrap">
            {s.num}
          </div>
          {/* The label CAN wrap — at lg breakpoint (6 cols) several
              labels exceed the cell width ("Landing Zones from scratch",
              "Azure subscriptions governed"). Without wrapping they
              overflow into the neighbouring cell. text-balance asks the
              browser to distribute the wrap points evenly so a 2-line
              label looks intentional rather than orphaned. */}
          <div class="text-muted mt-2 text-[13px] leading-snug text-balance">
            {t(s.labelKey, locale)}
          </div>
        </div>
      ))
    }
  </div>
</section>
