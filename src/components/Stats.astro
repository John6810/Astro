---
// Ordered experience -> scope -> impact, 6 cells matching the lg:grid-cols-6 layout.
const stats = [
  { num: "15+", labelKey: "stat_years_label", label: "ans d'IT" },
  { num: "5+", labelKey: "stat_azure_label", label: "ans sur Azure" },
  { num: "4", labelKey: "stat_alz_label", label: "Landing Zones from scratch" },
  { num: "26", labelKey: "stat_subscriptions_label", label: "souscriptions Azure gouvernées" },
  { num: "500K€+", labelKey: "stat_budget_label", label: "budget piloté" },
  { num: "35+", labelKey: "stat_trained_label", label: "ingénieurs formés" },
];
---

<section aria-label="Key figures" class="card overflow-hidden">
  <div class="bg-line grid grid-cols-2 gap-px sm:grid-cols-3 lg:grid-cols-6">
    {
      stats.map((s) => (
        <div class="bg-paper flex min-h-[110px] flex-col items-center justify-center p-5 text-center">
          <div class="text-accent text-3xl leading-none font-extrabold tracking-tight whitespace-nowrap">
            {s.num}
          </div>
          <div
            class="text-muted mt-2 text-[13px] leading-snug whitespace-nowrap"
            data-i18n={s.labelKey}
          >
            {s.label}
          </div>
        </div>
      ))
    }
  </div>
</section>
