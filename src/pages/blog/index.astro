---
import "@fontsource-variable/geist-mono";
import "../../styles/global.css";

import { getCollection, type CollectionEntry } from "astro:content";
import readingTimeFn from "reading-time";

import BaseHead from "../../components/BaseHead.astro";
import Analytics from "../../components/Analytics.astro";
import FloatingTheme from "../../components/FloatingTheme.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import { withBase } from "../../lib/url";

type BlogPost = CollectionEntry<"blog">;

// In dev, show drafts. In prod, hide them.
const allPosts = await getCollection("blog", ({ data }: BlogPost) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts
  .sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p: BlogPost) => ({
    ...p,
    minutes: readingTimeFn(p.body ?? "").minutes,
  }));

const title = "Blog — Jonathan Aerts";
const description =
  "Notes sur Azure Landing Zone, Terraform/Terragrunt, AKS et plateformes cloud sous régulation.";
const blogPath = withBase("/blog/");
const canonicalURL = Astro.site ? new URL(blogPath, Astro.site).toString() : blogPath;
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={title} description={description} canonicalURL={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' gc.zgo.at; img-src 'self' data:; font-src 'self'; connect-src 'self' *.goatcounter.com"
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var prefersDark =
            window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          var dark = stored ? stored === "dark" : prefersDark;
          if (dark) document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="font-body text-ink">
    <a href="#main" class="skip-to-content">Skip to content</a>

    <FloatingTheme />

    <div class="flex w-full justify-center px-4 py-6 sm:px-8 sm:py-12 lg:py-16">
      <main id="main" class="flex w-full max-w-4xl flex-col gap-8">
        <!-- Back link -->
        <nav class="no-print">
          <a
            href={withBase("/recruiter")}
            class="text-muted hover:text-accent inline-flex items-center gap-1.5 text-sm font-medium transition"
          >
            <span aria-hidden="true">←</span>
            <span>Retour au profil</span>
          </a>
        </nav>

        <header class="card flex flex-col gap-3 p-8">
          <span class="text-muted font-mono text-[11px] tracking-[0.12em] uppercase">Blog</span>
          <h1 class="text-ink text-3xl leading-tight font-extrabold tracking-tight sm:text-4xl">
            Blog
          </h1>
          <p class="text-muted max-w-2xl text-base leading-relaxed sm:text-[17px]">
            {description}
          </p>
        </header>

        {
          posts.length === 0 ? (
            <div class="card text-muted p-8 text-center">
              <p class="text-sm">Aucun article publié pour l'instant. Repassez bientôt.</p>
            </div>
          ) : (
            <div class="grid gap-4 sm:grid-cols-2">
              {posts.map((p: BlogPost & { minutes: number }) => (
                <BlogCard
                  href={withBase(`/blog/${p.id}/`)}
                  title={p.data.title}
                  description={p.data.description}
                  pubDate={p.data.pubDate}
                  minutes={p.minutes}
                  tags={p.data.tags}
                  lang={p.data.lang}
                  draft={p.data.draft}
                />
              ))}
            </div>
          )
        }

        <Footer />
      </main>
    </div>

    <Analytics />
  </body>
</html>
