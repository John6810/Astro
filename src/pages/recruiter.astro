---
import RecruiterLayout from "../layouts/RecruiterLayout.astro";
import Header from "../components/Header.astro";
import Stats from "../components/Stats.astro";
import Experience from "../components/Experience.astro";
import Skills from "../components/Skills.astro";
import SelectedProjects from "../components/SelectedProjects.astro";
import Education from "../components/Education.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import SideNav from "../components/SideNav.astro";
import FloatingTheme from "../components/FloatingTheme.astro";
---

<RecruiterLayout
  title="Jonathan Aerts — Senior Cloud Platform Architect | Azure Landing Zone | Belgium · Luxembourg"
  description="Senior Cloud Platform Architect, 15+ years IT. Azure Landing Zones from scratch, Terraform/GitOps, enterprise governance. Belgium · Luxembourg · EU Remote."
  canonicalURL="https://jonathan-aerts.dev/recruiter"
>
  <FloatingTheme />

  <div class="flex w-full items-start justify-center xl:relative xl:left-7">
    <main
      class="w-full max-w-5xl space-y-4 px-2 py-3 sm:space-y-6 sm:px-8 sm:py-12 lg:space-y-8 lg:py-20"
    >
      <Header />
      <Stats />
      <Experience />
      <Skills />
      <SelectedProjects />
      <Education />
      <Contact />
      <Footer />
    </main>

    <SideNav />
  </div>

  <script>
    import "../scripts/i18n";
  </script>
</RecruiterLayout>
